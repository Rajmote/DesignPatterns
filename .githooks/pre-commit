#!/bin/sh
# Local quality gate — runs before every commit.
# Activate once per clone:  git config core.hooksPath .githooks
set -e

SLN="DesignPatterns.sln"

echo "[pre-commit] Verifying formatting (.editorconfig)..."
if ! dotnet format "$SLN" --verify-no-changes --verbosity minimal; then
  echo ""
  echo "❌ Formatting issues found."
  echo "   Fix them with:  dotnet format $SLN"
  echo "   then 'git add' the changes and commit again."
  exit 1
fi

echo "[pre-commit] Building (Debug)..."
if ! dotnet build "$SLN" --nologo --verbosity quiet; then
  echo ""
  echo "❌ Build failed — commit aborted."
  exit 1
fi

echo "✅ pre-commit checks passed."
